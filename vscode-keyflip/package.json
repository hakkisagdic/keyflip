{
  "name": "keyflip-vscode",
  "displayName": "keyflip — Keyflip",
  "description": "Shows the active Claude account in the status bar and switches accounts via the keyflip CLI.",
  "version": "0.3.0",
  "publisher": "hakkisagdic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hakkisagdic/keyflip.git",
    "directory": "vscode-keyflip"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "keyflip.switch",
        "title": "keyflip: Switch Claude Account"
      },
      {
        "command": "keyflip.refresh",
        "title": "keyflip: Refresh Account Status"
      },
      {
        "command": "keyflip.dashboard",
        "title": "keyflip: Open Dashboard"
      },
      {
        "command": "keyflip.status",
        "title": "keyflip: Show Account Status"
      },
      {
        "command": "keyflip.rebind",
        "title": "keyflip: Re-link Chat History (moved folder)"
      },
      {
        "command": "keyflip.switchTo",
        "title": "keyflip: Switch to this account"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "keyflipAccounts",
          "name": "Claude Accounts (keyflip)"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "keyflip.switchTo",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "keyflip.refresh",
          "when": "view == keyflipAccounts",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "keyflip",
      "properties": {
        "keyflip.path": {
          "type": "string",
          "default": "keyflip",
          "description": "Path to the keyflip executable (default: resolve from PATH)."
        }
      }
    }
  }
}
